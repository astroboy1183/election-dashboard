# Template for the SMTP credentials used by the daily ECI probe.
#
# Setup:
#   1. Create a Gmail App Password (Google Account → Security → 2-Step
#      Verification must be on → App passwords → "Mail" → generate 16-char
#      password). Use that as SMTP_PASS below, NOT your Gmail login password.
#   2. Copy this file to ~/.config/election-dashboard/smtp.env and fill in
#      real values:
#        mkdir -p ~/.config/election-dashboard
#        cp scripts/smtp.env.example ~/.config/election-dashboard/smtp.env
#        chmod 600 ~/.config/election-dashboard/smtp.env
#        $EDITOR ~/.config/election-dashboard/smtp.env
#   3. probe_eci.sh auto-sources this file when present; if absent, it
#      silently skips email (desktop notify still fires).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
ALERT_FROM=you@gmail.com
ALERT_TO=jayanth_appalla@rediffmail.com
