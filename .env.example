# Template for `.env` — copy to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
#
# Then restart the backend so it picks up the new values.

# Anthropic API key — powers the "Ask the dashboard", state-story, and Compare features.
# Get one at https://console.anthropic.com → Settings → API Keys.
# Without this set, the /api/ai/* endpoints return HTTP 503; the rest of the
# dashboard still works.
ANTHROPIC_API_KEY=sk-ant-replace-me
